def reproject_vector_layer(input_layer, target_crs, output_path,
                            layer_name, feedback):
    feedback.pushInfo(f"Reprojecting vector layer: {layer_name}")

    result = processing.run(
        "native:reprojectlayer",
        {
            'INPUT':      input_layer,
            'TARGET_CRS': target_crs,
            'OUTPUT':     output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException(
            f"Failed to reproject vector layer: {layer_name}"
        )

    feedback.pushInfo(f"{layer_name} reprojected: {output}")
    return output


def reproject_raster_layer(input_layer, target_crs, output_path,
                            layer_name, resampling_method, feedback):
    feedback.pushInfo(f"Reprojecting raster layer: {layer_name}")

    result = processing.run(
        "gdal:warpreproject",
        {
            'INPUT':             input_layer,
            'SOURCE_CRS':        None,
            'TARGET_CRS':        target_crs,
            'RESAMPLING':        resampling_method,
            'NODATA':            None,
            'TARGET_RESOLUTION': None,
            'OPTIONS':           '',
            'DATA_TYPE':         0,
            'TARGET_EXTENT':     None,
            'TARGET_EXTENT_CRS': None,
            'MULTITHREADING':    False,
            'EXTRA':             '',
            'OUTPUT':            output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException(
            f"Failed to reproject raster layer: {layer_name}"
        )

    feedback.pushInfo(f"{layer_name} reprojected: {output}")
    return output


def reproject_inputs(validated_layers, target_crs, workspace, feedback):
    reprojected_folder = ensure_folder(
        os.path.join(workspace, "02_reprojected")
    )

    feedback.pushInfo("")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo("STEP: REPROJECTION")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo(f"Target CRS: {target_crs.authid()}")

    crs_code = target_crs.authid().replace("EPSG:", "")

    # FIX 2: Added missing road_reproj, settlement_reproj, lake_reproj
    aoi_reproj        = os.path.join(reprojected_folder, f"AOI_{crs_code}.gpkg")
    river_reproj      = os.path.join(reprojected_folder, f"Rivers_{crs_code}.gpkg")
    road_reproj       = os.path.join(reprojected_folder, f"Roads_{crs_code}.gpkg")
    settlement_reproj = os.path.join(reprojected_folder, f"Settlements_{crs_code}.gpkg")
    lake_reproj       = os.path.join(reprojected_folder, f"Lakes_{crs_code}.gpkg")
    dem_reproj        = os.path.join(reprojected_folder, f"DEM_{crs_code}.tif")
    rainfall_reproj   = os.path.join(reprojected_folder, f"Rainfall_{crs_code}.tif")
    lulc_reproj       = os.path.join(reprojected_folder, f"LULC_{crs_code}.tif")

    # --- Vector Reprojection ---
    aoi_out = reproject_vector_layer(
        validated_layers["AOI"], target_crs, aoi_reproj, "AOI", feedback
    )
    river_out = reproject_vector_layer(
        validated_layers["Rivers"], target_crs, river_reproj, "Rivers", feedback
    )
    road_out = reproject_vector_layer(
        validated_layers["Roads"], target_crs, road_reproj, "Roads", feedback
    )
    settlement_out = reproject_vector_layer(
        validated_layers["Settlements"], target_crs,
        settlement_reproj, "Settlements", feedback
    )
    lake_out = reproject_vector_layer(
        validated_layers["Lakes"], target_crs, lake_reproj, "Lakes", feedback
    )

    # --- Raster Reprojection ---
    # 0 = Nearest Neighbour, 1 = Bilinear
    dem_out = reproject_raster_layer(
        validated_layers["DEM"], target_crs, dem_reproj, "DEM", 0, feedback
    )
    rainfall_out = reproject_raster_layer(
        validated_layers["Rainfall"], target_crs,
        rainfall_reproj, "Rainfall", 1, feedback
    )
    lulc_out = reproject_raster_layer(
        validated_layers["LULC"], target_crs, lulc_reproj, "LULC", 0, feedback
    )

    feedback.pushInfo("")
    feedback.pushInfo("All layers reprojected successfully.")

    return {
        "AOI":         aoi_out,
        "Rivers":      river_out,
        "Roads":       road_out,
        "Settlements": settlement_out,
        "Lakes":       lake_out,
        "DEM":         dem_out,
        "Rainfall":    rainfall_out,
        "LULC":        lulc_out
    }


