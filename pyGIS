def generate_reclass_summary_excel(all_parameters, workspace, feedback):
    """
    Creates Excel workbook for reclassification review.
    Generates summary statistics, quantile tables,
    classification templates and flood risk scoring sheets.
    """
    summary_folder = ensure_folder(
        os.path.join(workspace, "06_summary")
    )
    out_excel = os.path.join(summary_folder, "Reclass_Assessment.xlsx")

    feedback.pushInfo("")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo("STEP: GENERATE RECLASS SUMMARY EXCEL")
    feedback.pushInfo("=" * 40)

    rasters = {
        "Elevation":            all_parameters["Elevation"],
        "LULC":                 all_parameters["LULC"],
        "Slope":                all_parameters["Slope"],
        "Rainfall":             all_parameters["Rainfall"],
        "FlowAccumulation":     all_parameters["FlowAccumulation"],
        "DistanceToRiver":      all_parameters["DistanceToRiver"],
        "DistanceToRoad":       all_parameters["DistanceToRoad"],
        "DistanceToSettlement": all_parameters["DistanceToSettlement"],
        "DistanceToLake":       all_parameters["DistanceToLake"],
    }

    wb            = Workbook()
    default_sheet = wb.active
    wb.remove(default_sheet)

    # --- Summary Sheet ---
    summary_ws = wb.create_sheet("Summary")
    add_excel_header(summary_ws, 1, [
        "Raster", "Path", "Valid_Count",
        "Min", "Max", "Mean", "StdDev",
        "Q10", "Q20", "Q25", "Q40",
        "Q50", "Q60", "Q75", "Q80", "Q90"
    ])

    summary_row              = 2
    continuous_for_quantiles = [
        "Elevation", "Rainfall", "FlowAccumulation"
    ]

    for name, path in rasters.items():
        if not os.path.exists(path):
            feedback.pushInfo(f"{name} missing: {path}")
            continue

        feedback.pushInfo(f"Processing summary for: {name}")

        arr, ds, nodata = read_raster_array(path)
        stats           = raster_summary(arr)

        if stats is None:
            feedback.pushInfo(f"No valid cells in {name}")
            continue

        # --- Write Summary Row ---
        summary_ws.cell(summary_row, 1,  name)
        summary_ws.cell(summary_row, 2,  path)
        summary_ws.cell(summary_row, 3,  stats["count_valid"])
        summary_ws.cell(summary_row, 4,  stats["min"])
        summary_ws.cell(summary_row, 5,  stats["max"])
        summary_ws.cell(summary_row, 6,  stats["mean"])
        summary_ws.cell(summary_row, 7,  stats["std"])
        summary_ws.cell(summary_row, 8,  stats["q10"])
        summary_ws.cell(summary_row, 9,  stats["q20"])
        summary_ws.cell(summary_row, 10, stats["q25"])
        summary_ws.cell(summary_row, 11, stats["q40"])
        summary_ws.cell(summary_row, 12, stats["q50"])
        summary_ws.cell(summary_row, 13, stats["q60"])
        summary_ws.cell(summary_row, 14, stats["q75"])
        summary_ws.cell(summary_row, 15, stats["q80"])
        summary_ws.cell(summary_row, 16, stats["q90"])
        summary_row += 1

        # --- Quantile Sheets (Continuous Parameters) ---
        if name in continuous_for_quantiles:
            ws = wb.create_sheet(f"{name}_Quantiles")
            add_excel_header(ws, 1, ["Metric", "Value"])

            quantile_rows = [
                ("Min", stats["min"]),  ("Q10", stats["q10"]),
                ("Q20", stats["q20"]),  ("Q25", stats["q25"]),
                ("Q40", stats["q40"]),  ("Q50", stats["q50"]),
                ("Q60", stats["q60"]),  ("Q75", stats["q75"]),
                ("Q80", stats["q80"]),  ("Q90", stats["q90"]),
                ("Max", stats["max"]),
            ]

            r = 2
            for metric, value in quantile_rows:
                ws.cell(r, 1, metric)
                ws.cell(r, 2, value)
                r += 1

            r += 1
            add_excel_header(
                ws, r,
                ["Suggested_Class", "From", "To", "Risk_Score"]
            )
            r += 1

            suggested = [
                ("Class 1", stats["min"], stats["q20"], ""),
                ("Class 2", stats["q20"], stats["q40"], ""),
                ("Class 3", stats["q40"], stats["q60"], ""),
                ("Class 4", stats["q60"], stats["q80"], ""),
                ("Class 5", stats["q80"], stats["max"], ""),
            ]
            for row in suggested:
                for c, val in enumerate(row, start=1):
                    ws.cell(r, c, val)
                r += 1

            r += 1
            if name == "Elevation":
                ws.cell(r, 1, "Flood logic")
                ws.cell(r, 2, "Lower elevation = higher risk")
            elif name == "Rainfall":
                ws.cell(r, 1, "Flood logic")
                ws.cell(r, 2, "Higher rainfall = higher risk")
            elif name == "FlowAccumulation":
                ws.cell(r, 1, "Flood logic")
                ws.cell(r, 2, "Higher flow accumulation = higher risk")

        # --- LULC Categories Sheet ---
