def rasterize_vector_to_dem_grid(vector_path, dem_path, output_path,
                                  layer_name, feedback):
    """
    Generic rasterization aligned to DEM grid.
    Replaces four separate rasterize functions.
    """
    dem_layer = QgsRasterLayer(dem_path, "DEM_REF")

    if not dem_layer.isValid():
        raise QgsProcessingException(
            f"DEM reference raster could not be loaded "
            f"for {layer_name} rasterization."
        )

    pixel_size_x = dem_layer.rasterUnitsPerPixelX()
    pixel_size_y = dem_layer.rasterUnitsPerPixelY()

    feedback.pushInfo(f"Rasterizing {layer_name}...")
    feedback.pushInfo(f"DEM Cell Size X: {pixel_size_x}")
    feedback.pushInfo(f"DEM Cell Size Y: {pixel_size_y}")

    result = processing.run(
        "gdal:rasterize",
        {
            'INPUT':     vector_path,
            'FIELD':     None,
            'BURN':      1,
            'USE_Z':     False,
            'UNITS':     1,
            'WIDTH':     pixel_size_x,
            'HEIGHT':    pixel_size_y,
            'EXTENT':    dem_path,
            'NODATA':    0,
            'OPTIONS':   '',
            'DATA_TYPE': 5,
            'INIT':      0,
            'INVERT':    False,
            'EXTRA':     '',
            'OUTPUT':    output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException(f"Failed to rasterize {layer_name}.")

    feedback.pushInfo(f"{layer_name} raster generated: {output}")
    return output


def generate_proximity_raster(input_raster, output_path,
                               layer_name, feedback):
    """
    Generic GDAL proximity raster generation.
    Replaces four separate proximity functions.
    """
    feedback.pushInfo(f"Generating distance-to-{layer_name} raster...")

    result = processing.run(
        "gdal:proximity",
        {
            'INPUT':        input_raster,
            'BAND':         1,
            'VALUES':       '1',
            'UNITS':        0,
            'MAX_DISTANCE': None,
            'REPLACE':      0,
            'NODATA':       0,
            'OPTIONS':      '',
            'EXTRA':        '',
            'DATA_TYPE':    5,
            'OUTPUT':       output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException(
            f"Failed to generate distance-to-{layer_name} raster."
        )

    feedback.pushInfo(f"Distance-to-{layer_name} raster generated: {output}")
    return output


