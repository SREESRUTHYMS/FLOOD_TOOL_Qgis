    RAINFALL       = "RAINFALL"
    LULC           = "LULC"
    RIVERS         = "RIVERS"
    ROADS          = "ROADS"
    SETTLEMENTS    = "SETTLEMENTS"
    LAKES          = "LAKES"
    OUTPUT         = "OUTPUT"
    FLOW_THRESHOLD = "FLOW_THRESHOLD"
    MEMORY         = "MEMORY"

    def name(self):
        return "flood_phase1"

    def displayName(self):
        return "Flood Estimation - Phase 1 (Preparation + Excel)"

    def group(self):
        return "Flood Tools"

    def groupId(self):
        return "flood_tools"

    def shortHelpString(self):
        return (
            "Runs Phase 1 of the flood susceptibility estimation workflow.\n\n"
            "Performs:\n"
            "  1. Input validation and geometry checks\n"
            "  2. Coordinate reprojection\n"
            "  3. AOI-based clipping\n"
            "  4. Model input raster preparation and grid alignment\n"
            "  5. Terrain parameter derivation\n"
            "     (Slope, Flow Accumulation, Flow Direction)\n"
            "  6. Proximity parameter generation\n"
            "     (Distance to River, Road, Settlement, Lake)\n"
            "  7. Automated Excel reclassification report\n\n"
            "Outputs all flood conditioning parameters as\n"
            "analysis-ready raster layers."
        )

    def initAlgorithm(self, config=None):

        self.addParameter(
            QgsProcessingParameterRasterLayer(
                self.DEM, "DEM Raster"
            )
        )
        self.addParameter(
            QgsProcessingParameterVectorLayer(
                self.AOI, "AOI Boundary",
                [QgsProcessing.TypeVectorPolygon]
            )
        )
        self.addParameter(
            QgsProcessingParameterRasterLayer(
                self.RAINFALL, "Rainfall Raster"
            )
        )
        self.addParameter(
            QgsProcessingParameterRasterLayer(
                self.LULC, "LULC Raster"
            )
        )
        self.addParameter(
            QgsProcessingParameterVectorLayer(
                self.RIVERS, "River Layer",
                [QgsProcessing.TypeVectorLine]
            )
        )
        self.addParameter(
            QgsProcessingParameterVectorLayer(
                self.ROADS, "Road Layer",
                [QgsProcessing.TypeVectorLine]
            )
        )
        self.addParameter(
            QgsProcessingParameterVectorLayer(
                self.SETTLEMENTS, "Settlement Layer",
                [QgsProcessing.TypeVectorPolygon]
            )
        )
        self.addParameter(
            QgsProcessingParameterVectorLayer(
                self.LAKES, "Lake Layer",
                [QgsProcessing.TypeVectorPoint]
            )
        )
        self.addParameter(
            QgsProcessingParameterFolderDestination(
                self.OUTPUT, "Output Workspace Folder"
            )
        )
        self.addParameter(
            QgsProcessingParameterNumber(
                self.FLOW_THRESHOLD,
                "Flow Accumulation Threshold",
                type=QgsProcessingParameterNumber.Integer,
                defaultValue=1000
            )
        )
        self.addParameter(
            QgsProcessingParameterNumber(
                self.MEMORY,
                "GRASS Memory (MB)",
                type=QgsProcessingParameterNumber.Integer,
                defaultValue=300
            )
        )

    def processAlgorithm(self, parameters, context, feedback):

        # --- Get Inputs ---
        dem_layer        = self.parameterAsRasterLayer(
            parameters, self.DEM,         context)
        aoi_layer        = self.parameterAsVectorLayer(
            parameters, self.AOI,         context)
        rainfall_layer   = self.parameterAsRasterLayer(
            parameters, self.RAINFALL,    context)
        lulc_layer       = self.parameterAsRasterLayer(
            parameters, self.LULC,        context)
        river_layer      = self.parameterAsVectorLayer(
            parameters, self.RIVERS,      context)
        road_layer       = self.parameterAsVectorLayer(
            parameters, self.ROADS,       context)
        settlement_layer = self.parameterAsVectorLayer(
            parameters, self.SETTLEMENTS, context)
        lake_layer       = self.parameterAsVectorLayer(
            parameters, self.LAKES,       context)
        workspace        = self.parameterAsString(
            parameters, self.OUTPUT,      context)
        flow_threshold   = self.parameterAsInt(
            parameters, self.FLOW_THRESHOLD, context)
        memory           = self.parameterAsInt(
            parameters, self.MEMORY,      context)

        target_crs = QgsCoordinateReferenceSystem("EPSG:32643")

        # --- Create Workspace ---
        if not os.path.exists(workspace):
            os.makedirs(workspace)

        feedback.pushInfo("=" * 40)
        feedback.pushInfo("FLOOD PHASE 1 — STARTING PROCESSING")
        feedback.pushInfo("=" * 40)

        # --- Stage 1: Validation ---
        validated = validate_inputs(
            dem_layer, aoi_layer, rainfall_layer, lulc_layer,
            river_layer, road_layer, settlement_layer, lake_layer,
            feedback
        )

        # --- Stage 2: Reprojection ---
        reproj = reproject_inputs(
            validated, target_crs, workspace, feedback
        )

        # --- Stage 3: Clipping ---
        clipped = clip_inputs_to_aoi(reproj, workspace, feedback)

        # --- Stage 4: Model Input Preparation ---
        model_inputs = prepare_model_input_rasters(
            clipped, workspace, feedback
        )

        # --- Stage 5: Terrain Parameters ---
        terrain = prepare_terrain_parameters(
            model_inputs, workspace, flow_threshold, memory, feedback
        )

        # --- Stage 6: Proximity Parameters ---
        # Each function chains output of previous as input
        river_params      = prepare_river_distance_parameter(
            terrain,       workspace, feedback
        )
        road_params       = prepare_road_distance_parameter(
            river_params,  workspace, feedback
        )
        settlement_params = prepare_settlement_distance_parameter(
            road_params,   workspace, feedback
        )
        all_params        = prepare_lake_distance_parameter(
            settlement_params, workspace, feedback
        )

        # --- Stage 7: Excel Report ---
        summary = generate_reclass_summary_excel(
            all_params, workspace, feedback
        )

        feedback.pushInfo("")
        feedback.pushInfo("=" * 40)
        feedback.pushInfo("FLOOD PHASE 1 COMPLETED SUCCESSFULLY!")
        feedback.pushInfo("=" * 40)
        feedback.pushInfo(f"Excel Report : {summary['ReclassExcel']}")
        feedback.pushInfo(f"Workspace    : {workspace}")

        return {
            "Excel_Output": summary["ReclassExcel"]
        }

    def createInstance(self):
        return FloodPhase1Tool()
