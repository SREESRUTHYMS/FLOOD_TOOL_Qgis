def generate_slope(dem_path, output_path, feedback):
    feedback.pushInfo("Generating slope raster...")

    result = processing.run(
        "gdal:slope",
        {
            'INPUT':         dem_path,
            'BAND':          1,
            'SCALE':         1,
            'AS_PERCENT':    False,
            'COMPUTE_EDGES': False,
            'ZEVENBERGEN':   False,
            'OPTIONS':       '',
            'EXTRA':         '',
            'OUTPUT':        output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException("Failed to generate slope raster.")

    feedback.pushInfo(f"Slope generated: {output}")
    return output


def generate_flow_products(dem_path, flow_acc_out, flow_dir_out,
                           threshold, memory_mb, feedback):
    feedback.pushInfo(
        "Generating flow accumulation and flow direction "
        "using GRASS r.watershed..."
    )

    try:
        result = processing.run(
            "grass7:r.watershed",
            {
                'elevation':                       dem_path,
                'depression':                      None,
                'flow':                            None,
                'disturbed_land':                  None,
                'blocking':                        None,
                'threshold':                       threshold,
                'memory':                          memory_mb,
                '-s':                              False,
                '-4':                              False,
                '-m':                              False,
                'accumulation':                    flow_acc_out,
                'drainage':                        flow_dir_out,
                'basin':                           'TEMPORARY_OUTPUT',
                'stream':                          'TEMPORARY_OUTPUT',
                'half_basin':                      'TEMPORARY_OUTPUT',
                'length_slope':                    'TEMPORARY_OUTPUT',
                'slope_steepness':                 'TEMPORARY_OUTPUT',
                'tci':                             'TEMPORARY_OUTPUT',
                'spi':                             'TEMPORARY_OUTPUT',
                'GRASS_REGION_PARAMETER':          None,
                'GRASS_REGION_CELLSIZE_PARAMETER': 0,
                'GRASS_RASTER_FORMAT_OPT':         '',
                'GRASS_RASTER_FORMAT_META':        ''
            }
        )
    except Exception as e:
        raise QgsProcessingException(
            f"GRASS watershed processing failed. "
            f"Ensure GRASS provider is enabled in QGIS. "
            f"Details: {str(e)}"
        )

    if not os.path.exists(flow_acc_out):
        raise QgsProcessingException(
            "Flow accumulation output was not created."
        )
    if not os.path.exists(flow_dir_out):
        raise QgsProcessingException(
            "Flow direction output was not created."
        )

    feedback.pushInfo(f"Flow accumulation saved: {flow_acc_out}")
    feedback.pushInfo(f"Flow direction saved:    {flow_dir_out}")

    return {
        "FlowAccumulation": flow_acc_out,
        "FlowDirection":    flow_dir_out
    }


def prepare_terrain_parameters(model_inputs, workspace,
                                flow_threshold, grass_memory_mb, feedback):
    parameter_folder = ensure_folder(
        os.path.join(workspace, "05_parameters")
    )

    feedback.pushInfo("")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo("STEP: PREPARE TERRAIN PARAMETERS")
    feedback.pushInfo("=" * 40)

    elevation_path = model_inputs["Elevation"]

    slope_out    = os.path.join(parameter_folder, "Slope.tif")
    flow_acc_out = os.path.join(parameter_folder, "FlowAccumulation.tif")
    flow_dir_out = os.path.join(parameter_folder, "FlowDirection.tif")

    slope_path   = generate_slope(elevation_path, slope_out, feedback)

    flow_outputs = generate_flow_products(
        elevation_path,
        flow_acc_out,
        flow_dir_out,
        flow_threshold,
        grass_memory_mb,
        feedback
    )

    feedback.pushInfo("")
    feedback.pushInfo("Terrain parameters prepared successfully.")

    # FIX 4: Replaced clipped_layers with model_inputs
    return {
        "Elevation":        elevation_path,
        "Rainfall":         model_inputs["Rainfall"],
        "LULC":             model_inputs["LULC"],
        "Slope":            slope_path,
        "FlowAccumulation": flow_outputs["FlowAccumulation"],
        "FlowDirection":    flow_outputs["FlowDirection"],
        "AOI":              model_inputs["AOI"],
