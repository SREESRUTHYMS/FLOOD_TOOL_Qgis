            ])
            template = [
                (0,    100,    "", "Closest to road = high runoff & drainage obstruction"),
                (100,  300,    "", "Near road"),
                (300,  600,    "", "Moderate influence"),
                (600,  1000,   "", "Low influence"),
                (1000, 999999, "", "Far from road = lowest influence"),
            ]
            r = 2
            for row in template:
                for c, val in enumerate(row, start=1):
                    ws.cell(r, c, val)
                r += 1

        # --- Distance to Settlement Template ---
        if name == "DistanceToSettlement":
            ws = wb.create_sheet("DistSettlement_Template")
