                "From_Meter", "To_Meter",
                "Risk_Score_1_to_5", "Reason"
            ])
            template = [
                (0,    200,    "", "Closest to settlement = high impervious surface"),
                (200,  500,    "", "Near settlement"),
                (500,  1000,   "", "Moderate influence"),
                (1000, 2000,   "", "Low influence"),
