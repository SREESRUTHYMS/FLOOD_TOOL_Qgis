                (250,  500,    "", "Near river"),
                (500,  1000,   "", "Moderate influence"),
                (1000, 2000,   "", "Low influence"),
                (2000, 999999, "", "Far from river = lowest influence"),
            ]
            r = 2
            for row in template:
                for c, val in enumerate(row, start=1):
                    ws.cell(r, c, val)
                r += 1

        # --- Distance to Road Template ---
        if name == "DistanceToRoad":
            ws = wb.create_sheet("DistRoad_Template")
