def get_raster_grid_info(raster_path, layer_name, feedback):
    raster_layer = QgsRasterLayer(raster_path, layer_name)

    if not raster_layer.isValid():
        raise QgsProcessingException(
            f"{layer_name} reference raster is invalid: {raster_path}"
        )

    extent = raster_layer.extent()
    xmin   = extent.xMinimum()
    xmax   = extent.xMaximum()
    ymin   = extent.yMinimum()
    ymax   = extent.yMaximum()

    width  = raster_layer.width()
    height = raster_layer.height()

    xres = (xmax - xmin) / width
    yres = (ymax - ymin) / height

    extent_string = f"{xmin},{xmax},{ymin},{ymax}"

    feedback.pushInfo("")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo("DEM REFERENCE GRID")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo(f"CRS:         {raster_layer.crs().authid()}")
    feedback.pushInfo(f"Width:       {width}")
    feedback.pushInfo(f"Height:      {height}")
    feedback.pushInfo(f"Pixel Size X:{xres}")
    feedback.pushInfo(f"Pixel Size Y:{yres}")
    feedback.pushInfo(f"Extent:      {extent_string}")

    return {
        "layer":         raster_layer,
        "crs":           raster_layer.crs(),
        "width":         width,
        "height":        height,
        "xres":          xres,
        "yres":          yres,
        "extent_string": extent_string
    }


def align_raster_to_reference(input_raster, ref_info, output_path,
                               layer_name, resampling_method, feedback):
    feedback.pushInfo(f"Aligning raster to DEM grid: {layer_name}")

    result = processing.run(
        "gdal:warpreproject",
        {
            'INPUT':             input_raster,
            'SOURCE_CRS':        None,
            'TARGET_CRS':        ref_info["crs"],
            'RESAMPLING':        resampling_method,
            'NODATA':            None,
            'TARGET_RESOLUTION': ref_info["xres"],
            'OPTIONS':           '',
            'DATA_TYPE':         0,
            'TARGET_EXTENT':     ref_info["extent_string"],
            'TARGET_EXTENT_CRS': ref_info["crs"],
            'MULTITHREADING':    False,
            'EXTRA':             '',
            'OUTPUT':            output_path
        }
    )
    output = result['OUTPUT']

    if not os.path.exists(output):
        raise QgsProcessingException(f"Failed to align raster: {layer_name}")

    feedback.pushInfo(f"{layer_name} aligned: {output}")
    return output


def prepare_model_input_rasters(clipped_layers, workspace, feedback):
    model_input_folder = ensure_folder(
        os.path.join(workspace, "04_model_input")
    )

    feedback.pushInfo("")
    feedback.pushInfo("=" * 40)
    feedback.pushInfo("STEP: PREPARE MODEL INPUT RASTERS")
    feedback.pushInfo("=" * 40)

    dem_path      = clipped_layers["DEM"]
    rainfall_path = clipped_layers["Rainfall"]
    lulc_path     = clipped_layers["LULC"]

    elevation_out = os.path.join(model_input_folder, "Elevation.tif")
    rainfall_out  = os.path.join(model_input_folder, "Rainfall.tif")
    lulc_out      = os.path.join(model_input_folder, "LULC.tif")

    ref_info = get_raster_grid_info(dem_path, "DEM_clip", feedback)

    shutil.copy(dem_path, elevation_out)
    feedback.pushInfo(f"Elevation saved: {elevation_out}")

    rainfall_aligned = align_raster_to_reference(
        rainfall_path, ref_info, rainfall_out, "Rainfall", 1, feedback
    )
    lulc_aligned = align_raster_to_reference(
        lulc_path, ref_info, lulc_out, "LULC", 0, feedback
    )

    feedback.pushInfo("")
    feedback.pushInfo("Model input rasters prepared successfully.")

    return {
        "Elevation":   elevation_out,
        "Rainfall":    rainfall_aligned,
        "LULC":        lulc_aligned,
        "DEM_REF":     dem_path,
        "REF_INFO":    ref_info,
        "AOI":         clipped_layers["AOI"],
        "Rivers":      clipped_layers["Rivers"],
        "Roads":       clipped_layers["Roads"],
        "Settlements": clipped_layers["Settlements"],
        "Lakes":       clipped_layers["Lakes"]
    }


